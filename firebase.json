{
  "hosting": [
    {
      "target": "camlabs",
      "public": "public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "**/*.apk"
      ],
      "headers": [
        {
          "source": "/sitemap.xml",
          "headers": [
            {
              "key": "Content-Type",
              "value": "application/xml"
            }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "/privacy.html",
          "destination": "/privacy.html"
        },
        {
          "source": "/terms.html",
          "destination": "/terms.html"
        },
        {
          "source": "/delete.html",
          "destination": "/delete.html"
        },
        {
          "source": "/404.html",
          "destination": "/404.html"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
